# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
#
# ⚠️  ROTATE any keys that were previously committed to git before deploying.

# === 1. MULTI-AGENT STATE MONITORING & TRACING ===
LANGSMITH_TRACING="true"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="lsv2_pt_<your-key-here>"
LANGSMITH_PROJECT="WelfareFlow-India"

# === 2. CORE SYSTEM & ROUTING LLM ===
GEMINI_API_KEY="AIza<your-key-here>"

# === 3. SOVEREIGN INDIC SPEECH & VISION PLATFORM ===
SARVAM_API_KEY="sk_<your-key-here>"
# Set to true to skip live Sarvam API calls (uses mock responses)
SARVAM_MOCK_MODE="false"

# === 4. ENTERPRISE RPA SYSTEM ===
UIPATH_ORCHESTRATOR_URL="https://cloud.uipath.com/your_org/your_tenant/orchestrator_"
UIPATH_CLIENT_ID="<generated under Admin -> External Applications>"
UIPATH_CLIENT_SECRET="<confidential application client secret>"
UIPATH_WEBHOOK_SECRET="<generate with: openssl rand -hex 32>"

# === 5. DATABASE & VAULT KEY ===
# Leave blank to auto-fallback to in-memory SQLite (development only)
DATABASE_URL="postgresql://postgres:password@localhost:5432/welfareflow"
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AADHAAR_VAULT_AES_KEY="<32-byte-urlsafe-base64-fernet-key>"

# === 6. APPLICATION ===
APP_ENV="development"   # development | staging | production
APP_CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
# Protect /api/admin/* endpoints. Generate with: openssl rand -hex 32
ADMIN_API_KEY=""        # leave blank to allow unauthenticated access in development

# === 7. SLA WATCHDOG ===
SLA_DAYS_THRESHOLD="14"
SLA_WATCHDOG_INTERVAL_SECONDS="3600"
SLA_WATCHDOG_ENABLED="true"
